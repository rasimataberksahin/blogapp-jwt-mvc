@model LoginViewModel
@* Bu view LoginViewModel ile çalışıyor.
   Yani formdan gelen Email ve Password alanları bu model ile binding yapılacak. *@

<div class="container py-5" style="max-width: 520px;">
    <div class="text-center mb-4">
        <h2 class="mb-1">Login</h2>
        <div class="text-muted small">Sign in to continue</div>
    </div>

    @* ViewBag.Error varsa ekranda düzgün gözüksün diye *@
    @if (ViewBag.Error is not null)
    {
        <div class="alert alert-danger py-2 small" role="alert">
            @ViewBag.Error
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-controller="Auth" asp-action="Login" method="post">
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="user1@gmail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" class="form-control" placeholder="••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Login
                </button>
            </form>
        </div>
    </div>

    <div class="text-center text-muted small mt-3">
        Demo users: user1@gmail.com / 1234
    </div>
</div>

@* Form submit edildiğinde:
           POST /Auth/Login çağrılır
           AuthController.Login([FromForm] LoginViewModel model) çalışır *@